<?xml version="1.0"?>
<robot name="amr_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ========================================================= -->
    <!-- AMR ROBOT - CORE GEOMETRY / KINEMATICS ONLY               -->
    <!-- Only geometry, sensor positions, links, joints            -->
    <!-- ========================================================= -->

    <!-- ===================== CONSTANTS ========================= -->
    <xacro:property name="pi_num" value="3.1415926535897931"/>

    <!-- ===================== BASE ============================== -->
    <xacro:property name="base_length" value="0.500"/>
    <xacro:property name="base_width"  value="0.400"/>
    <xacro:property name="base_height" value="0.150"/>
    <xacro:property name="base_mass"   value="20.0"/>
    <xacro:property name="ground_clearance" value="0.020"/>

    <!-- base_link at chassis geometric center -->
    <xacro:property name="base_link_z" value="${ground_clearance + base_height/2.0}"/>

    <!-- ===================== DRIVE WHEELS ====================== -->
    <xacro:property name="wheel_radius"      value="0.060"/>
    <xacro:property name="wheel_width"       value="0.030"/>
    <xacro:property name="wheel_mass"        value="2.0"/>
    <xacro:property name="wheel_separation"  value="0.440"/>
    <xacro:property name="wheel_x"           value="0.000"/>
    <xacro:property name="wheel_y"           value="${wheel_separation/2.0}"/>
    <xacro:property name="wheel_z"           value="${wheel_radius - base_link_z}"/>

    <!-- ===================== SUPPORT WHEELS ==================== -->
    <xacro:property name="caster_radius" value="0.030"/>
    <xacro:property name="caster_mass"   value="0.30"/>
    <xacro:property name="caster_x_front" value="0.205"/>
    <xacro:property name="caster_x_rear"  value="-0.205"/>
    <xacro:property name="caster_y"       value="0.155"/>
    <xacro:property name="caster_z"       value="${caster_radius - base_link_z}"/>

    <!-- ===================== LIDAR ============================= -->
    <xacro:property name="lidar_radius" value="0.038"/>
    <xacro:property name="lidar_height" value="0.055"/>
    <xacro:property name="lidar_x" value="0.200"/>
    <xacro:property name="lidar_y" value="0.000"/>
    <xacro:property name="lidar_z_from_ground" value="0.400"/>
    <xacro:property name="lidar_z" value="${lidar_z_from_ground - base_link_z}"/>
    <xacro:property name="lidar_roll"  value="0.0"/>
    <xacro:property name="lidar_pitch" value="0.0"/>
    <xacro:property name="lidar_yaw"   value="0.0"/>

    <!-- Square lidar pole -->
    <xacro:property name="lidar_pole_size_x" value="0.080"/>
    <xacro:property name="lidar_pole_size_y" value="0.080"/>
    <xacro:property name="lidar_pole_height" value="${lidar_z - lidar_height/2.0}"/>
    <xacro:property name="lidar_pole_z" value="${lidar_pole_height/2.0}"/>

    <!-- ===================== IMU =============================== -->
    <xacro:property name="imu_size_x" value="0.040"/>
    <xacro:property name="imu_size_y" value="0.040"/>
    <xacro:property name="imu_size_z" value="0.015"/>
    <xacro:property name="imu_mass"   value="0.05"/>
    <xacro:property name="imu_x" value="0.000"/>
    <xacro:property name="imu_y" value="0.000"/>

    <!-- moved inside robot, near upper inside surface -->
    <xacro:property name="imu_z_from_ground" value="0.155"/>
    <xacro:property name="imu_z" value="${imu_z_from_ground - base_link_z}"/>

    <xacro:property name="imu_roll"  value="0.0"/>
    <xacro:property name="imu_pitch" value="0.0"/>
    <xacro:property name="imu_yaw"   value="0.0"/>

    <!-- ===================== CAMERA ============================ -->
    <xacro:property name="camera_size_x" value="0.030"/>
    <xacro:property name="camera_size_y" value="0.030"/>
    <xacro:property name="camera_size_z" value="0.025"/>
    <xacro:property name="camera_mass"   value="0.03"/>
    <xacro:property name="camera_x" value="0.200"/>
    <xacro:property name="camera_y" value="0.000"/>
    <xacro:property name="camera_z_from_ground" value="0.120"/>
    <xacro:property name="camera_z" value="${camera_z_from_ground - base_link_z}"/>
    <xacro:property name="camera_roll"  value="0.0"/>
    <xacro:property name="camera_pitch" value="0.0"/>
    <xacro:property name="camera_yaw"   value="0.0"/>

    <!-- ===================== MATERIALS ========================= -->
    <material name="base_gray">
      <color rgba="0.35 0.35 0.38 1.0"/>
    </material>

    <material name="wheel_black">
      <color rgba="0.08 0.08 0.08 1.0"/>
    </material>

    <material name="sensor_blue">
      <color rgba="0.15 0.35 0.85 1.0"/>
    </material>

    <material name="sensor_green">
      <color rgba="0.10 0.65 0.25 1.0"/>
    </material>

    <material name="sensor_red">
      <color rgba="0.75 0.15 0.15 1.0"/>
    </material>

    <!-- ===================== MACROS ============================ -->
    <xacro:macro name="box_inertial" params="mass x y z">
      <inertial>
        <mass value="${mass}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia
          ixx="${(mass/12.0) * (y*y + z*z)}"
          ixy="0.0"
          ixz="0.0"
          iyy="${(mass/12.0) * (x*x + z*z)}"
          iyz="0.0"
          izz="${(mass/12.0) * (x*x + y*y)}"/>
      </inertial>
    </xacro:macro>

    <xacro:macro name="cylinder_y_inertial" params="mass radius length">
      <inertial>
        <mass value="${mass}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia
          ixx="${(mass/12.0) * (3.0*radius*radius + length*length)}"
          ixy="0.0"
          ixz="0.0"
          iyy="${0.5 * mass * radius * radius}"
          iyz="0.0"
          izz="${(mass/12.0) * (3.0*radius*radius + length*length)}"/>
      </inertial>
    </xacro:macro>

    <xacro:macro name="sphere_inertial" params="mass radius">
      <inertial>
        <mass value="${mass}"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia
          ixx="${0.4 * mass * radius * radius}"
          ixy="0.0"
          ixz="0.0"
          iyy="${0.4 * mass * radius * radius}"
          iyz="0.0"
          izz="${0.4 * mass * radius * radius}"/>
      </inertial>
    </xacro:macro>

    <!-- ===================== FRAMES ============================ -->
    <link name="base_footprint"/>

    <joint name="base_footprint_to_base_link" type="fixed">
      <parent link="base_footprint"/>
      <child link="base_link"/>
      <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
    </joint>

    <!-- ===================== BASE LINK ========================= -->
    <link name="base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
        <material name="base_gray"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="${base_length} ${base_width} ${base_height}"/>
        </geometry>
      </collision>

      <xacro:box_inertial mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
    </link>

    <!-- ===================== LEFT DRIVE WHEEL ================== -->
    <link name="left_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <xacro:cylinder_y_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="left_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="left_wheel_link"/>
      <origin xyz="${wheel_x} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- ===================== RIGHT DRIVE WHEEL ================= -->
    <link name="right_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <xacro:cylinder_y_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
    </link>

    <joint name="right_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="right_wheel_link"/>
      <origin xyz="${wheel_x} ${-wheel_y} ${wheel_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <!-- ===================== SIMPLE CASTERS ==================== -->
    <link name="front_left_caster_link">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="front_left_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="front_left_caster_link"/>
      <origin xyz="${caster_x_front} ${caster_y} ${caster_z}" rpy="0 0 0"/>
    </joint>

    <link name="front_right_caster_link">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="front_right_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="front_right_caster_link"/>
      <origin xyz="${caster_x_front} ${-caster_y} ${caster_z}" rpy="0 0 0"/>
    </joint>

    <link name="rear_left_caster_link">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="rear_left_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="rear_left_caster_link"/>
      <origin xyz="${caster_x_rear} ${caster_y} ${caster_z}" rpy="0 0 0"/>
    </joint>

    <link name="rear_right_caster_link">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
    </link>

    <joint name="rear_right_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="rear_right_caster_link"/>
      <origin xyz="${caster_x_rear} ${-caster_y} ${caster_z}" rpy="0 0 0"/>
    </joint>

    <!-- ===================== LIDAR SQUARE POLE ================ -->
    <link name="lidar_pole_link">
  <visual>
    <geometry>
      <box size="${lidar_pole_size_x} ${lidar_pole_size_y} ${lidar_pole_height}"/>
    </geometry>
    <material name="base_gray"/>
  </visual>

  <inertial>
    <mass value="0.001"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
  </inertial>
</link>

    <joint name="lidar_pole_joint" type="fixed">
      <parent link="base_link"/>
      <child link="lidar_pole_link"/>
      <origin xyz="${lidar_x} ${lidar_y} ${lidar_pole_z}" rpy="0 0 0"/>
    </joint>

    <!-- ===================== LIDAR BODY ======================== -->
    <link name="lidar_link">
  <visual>
    <geometry>
      <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
    </geometry>
    <material name="sensor_blue"/>
  </visual>

  <inertial>
    <mass value="0.001"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertia
      ixx="1e-6" ixy="0.0" ixz="0.0"
      iyy="1e-6" iyz="0.0"
      izz="1e-6"/>
  </inertial>
</link>

    <joint name="lidar_joint" type="fixed">
      <parent link="base_link"/>
      <child link="lidar_link"/>
      <origin xyz="${lidar_x} ${lidar_y} ${lidar_z}" rpy="${lidar_roll} ${lidar_pitch} ${lidar_yaw}"/>
    </joint>

    <!-- ===================== IMU BODY ========================== -->
    <link name="imu_link">
      <visual>
        <geometry>
          <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
        </geometry>
        <material name="sensor_green"/>
      </visual>

      <collision>
        <geometry>
          <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
        </geometry>
      </collision>

      <xacro:box_inertial mass="${imu_mass}" x="${imu_size_x}" y="${imu_size_y}" z="${imu_size_z}"/>
    </link>

    <joint name="imu_joint" type="fixed">
      <parent link="base_link"/>
      <child link="imu_link"/>
      <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="${imu_roll} ${imu_pitch} ${imu_yaw}"/>
    </joint>

    <!-- ===================== CAMERA BODY ======================= -->
    <link name="camera_link">
      <visual>
        <geometry>
          <box size="${camera_size_x} ${camera_size_y} ${camera_size_z}"/>
        </geometry>
        <material name="sensor_red"/>
      </visual>

      <collision>
        <geometry>
          <box size="${camera_size_x} ${camera_size_y} ${camera_size_z}"/>
        </geometry>
      </collision>

      <xacro:box_inertial mass="${camera_mass}" x="${camera_size_x}" y="${camera_size_y}" z="${camera_size_z}"/>
    </link>

    <joint name="camera_joint" type="fixed">
      <parent link="base_link"/>
      <child link="camera_link"/>
      <origin xyz="${camera_x} ${camera_y} ${camera_z}" rpy="${camera_roll} ${camera_pitch} ${camera_yaw}"/>
    </joint>

  </robot>