<?xml version="1.0"?>
<robot name="amr_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================= -->
  <!-- AMR REAL ROBOT DESCRIPTION                                -->
  <!-- Real robot only: geometry + frames                        -->
  <!-- Root body frame: base_link                                -->
  <!-- Convention: +x forward, +y left, +z up                    -->
  <!-- No Gazebo plugins                                         -->
  <!-- ========================================================= -->

  <!-- ===================== CONSTANTS ========================= -->
  <xacro:property name="pi_num" value="3.1415926535897931"/>

  <!-- ===================== BASE ============================== -->
  <xacro:property name="base_length" value="0.470"/>
  <xacro:property name="base_width"  value="0.430"/>
  <xacro:property name="base_height" value="0.130"/>
  <xacro:property name="base_mass"   value="4.0"/>
  <xacro:property name="ground_clearance" value="0.023"/>

  <!-- base_link is at chassis geometric center -->
  <xacro:property name="base_link_z" value="${ground_clearance + base_height/2.0}"/>

  <!-- ===================== DRIVE WHEELS ====================== -->
  <xacro:property name="wheel_radius"     value="0.060"/>
  <xacro:property name="wheel_width"      value="0.030"/>
  <xacro:property name="wheel_mass"       value="0.30"/>
  <xacro:property name="wheel_separation" value="0.435"/>

  <xacro:property name="wheel_x" value="0.000"/>
  <xacro:property name="wheel_y" value="${wheel_separation/2.0}"/>
  <xacro:property name="wheel_z" value="${wheel_radius - base_link_z}"/>

  <!-- ===================== CASTERS =========================== -->
  <xacro:property name="caster_radius" value="0.040"/>
  <xacro:property name="caster_width"  value="0.030"/>
  <xacro:property name="caster_mass"   value="0.10"/>

  <xacro:property name="caster_x_front" value="${ base_length/2.0 - caster_radius }"/>
  <xacro:property name="caster_x_rear"  value="${-base_length/2.0 + caster_radius }"/>
  <xacro:property name="caster_y_left"  value="${ base_width/2.0  - caster_radius }"/>
  <xacro:property name="caster_y_right" value="${-base_width/2.0  + caster_radius }"/>
  <xacro:property name="caster_z"       value="${caster_radius - base_link_z}"/>

  <!-- ===================== LIDAR ============================= -->
  <!-- Front side is +x -->
  <xacro:property name="lidar_radius" value="0.038"/>
  <xacro:property name="lidar_height" value="0.055"/>
  <xacro:property name="lidar_x" value="0.195"/>
  <xacro:property name="lidar_y" value="0.000"/>
  <xacro:property name="lidar_z_from_ground" value="0.388"/>
  <xacro:property name="lidar_z" value="${lidar_z_from_ground - base_link_z}"/>
  <xacro:property name="lidar_roll"  value="0.0"/>
  <xacro:property name="lidar_pitch" value="0.0"/>
  <xacro:property name="lidar_yaw"   value="${pi_num}"/>

  <xacro:property name="lidar_pole_size_x" value="0.030"/>
  <xacro:property name="lidar_pole_size_y" value="0.030"/>
  <xacro:property name="lidar_pole_height" value="${lidar_z - lidar_height/2.0}"/>
  <xacro:property name="lidar_pole_z" value="${lidar_pole_height/2.0}"/>

  <!-- ===================== IMU =============================== -->
  <xacro:property name="imu_size_x" value="0.040"/>
  <xacro:property name="imu_size_y" value="0.040"/>
  <xacro:property name="imu_size_z" value="0.015"/>
  <xacro:property name="imu_mass"   value="0.05"/>

  <xacro:property name="imu_x" value="0.000"/>
  <xacro:property name="imu_y" value="0.000"/>
  <xacro:property name="imu_z_from_ground" value="0.140"/>
  <xacro:property name="imu_z" value="${imu_z_from_ground - base_link_z}"/>
  <xacro:property name="imu_roll"  value="0.0"/>
  <xacro:property name="imu_pitch" value="0.0"/>
  <xacro:property name="imu_yaw"   value="0.0"/>

  <!-- ===================== MATERIALS ========================= -->
  <material name="base_gray">
    <color rgba="0.35 0.35 0.38 1.0"/>
  </material>

  <material name="wheel_black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <material name="sensor_blue">
    <color rgba="0.15 0.35 0.85 1.0"/>
  </material>

  <material name="sensor_green">
    <color rgba="0.10 0.65 0.25 1.0"/>
  </material>

  <!-- ===================== MACROS ============================ -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(mass/12.0) * (y*y + z*z)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${(mass/12.0) * (x*x + z*z)}"
        iyz="0.0"
        izz="${(mass/12.0) * (x*x + y*y)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_y_inertial" params="mass radius length">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${(mass/12.0) * (3.0*radius*radius + length*length)}"
        ixy="0.0"
        ixz="0.0"
        iyy="${0.5 * mass * radius * radius}"
        iyz="0.0"
        izz="${(mass/12.0) * (3.0*radius*radius + length*length)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertial" params="mass radius">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${0.4 * mass * radius * radius}"
        ixy="0.0"
        ixz="0.0"
        iyy="${0.4 * mass * radius * radius}"
        iyz="0.0"
        izz="${0.4 * mass * radius * radius}"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== BASE LINK ========================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="base_gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <xacro:box_inertial mass="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- ===================== LEFT DRIVE WHEEL ================== -->
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>

    <xacro:cylinder_y_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_x} ${wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== RIGHT DRIVE WHEEL ================= -->
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="${-pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>

    <xacro:cylinder_y_inertial mass="${wheel_mass}" radius="${wheel_radius}" length="${wheel_width}"/>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_x} ${-wheel_y} ${wheel_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ===================== CASTERS =========================== -->
  <link name="front_left_caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
  </link>

  <joint name="front_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_caster_link"/>
    <origin xyz="${caster_x_front} ${caster_y_left} ${caster_z}" rpy="0 0 0"/>
  </joint>

  <link name="front_right_caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
  </link>

  <joint name="front_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_right_caster_link"/>
    <origin xyz="${caster_x_front} ${caster_y_right} ${caster_z}" rpy="0 0 0"/>
  </joint>

  <link name="rear_left_caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
  </link>

  <joint name="rear_left_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_caster_link"/>
    <origin xyz="${caster_x_rear} ${caster_y_left} ${caster_z}" rpy="0 0 0"/>
  </joint>

  <link name="rear_right_caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="wheel_black"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertial mass="${caster_mass}" radius="${caster_radius}"/>
  </link>

  <joint name="rear_right_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_right_caster_link"/>
    <origin xyz="${caster_x_rear} ${caster_y_right} ${caster_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== LIDAR MAST ======================== -->
  <link name="lidar_pole_link">
    <visual>
      <geometry>
        <box size="${lidar_pole_size_x} ${lidar_pole_size_y} ${lidar_pole_height}"/>
      </geometry>
      <material name="base_gray"/>
    </visual>

    <collision>
      <geometry>
        <box size="${lidar_pole_size_x} ${lidar_pole_size_y} ${lidar_pole_height}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
    </inertial>
  </link>

  <joint name="lidar_pole_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_pole_link"/>
    <origin xyz="${lidar_x} ${lidar_y} ${lidar_pole_z}" rpy="0 0 0"/>
  </joint>

  <!-- ===================== LIDAR BODY ======================== -->
  <link name="lidar_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
      <material name="sensor_blue"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="${pi_num/2} 0 0"/>
      <geometry>
        <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="1e-4" ixy="0.0" ixz="0.0"
        iyy="1e-4" iyz="0.0"
        izz="1e-4"/>
    </inertial>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="lidar_pole_link"/>
    <child link="lidar_link"/>
    <origin xyz="0 0 ${lidar_height/2.0}" rpy="${lidar_roll} ${lidar_pitch} ${lidar_yaw}"/>
  </joint>

  <!-- ===================== IMU =============================== -->
  <link name="imu_link">
    <visual>
      <geometry>
        <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
      </geometry>
      <material name="sensor_green"/>
    </visual>

    <collision>
      <geometry>
        <box size="${imu_size_x} ${imu_size_y} ${imu_size_z}"/>
      </geometry>
    </collision>

    <xacro:box_inertial mass="${imu_mass}" x="${imu_size_x}" y="${imu_size_y}" z="${imu_size_z}"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="${imu_x} ${imu_y} ${imu_z}" rpy="${imu_roll} ${imu_pitch} ${imu_yaw}"/>
  </joint>

</robot>